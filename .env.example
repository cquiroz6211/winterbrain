# MCP_TRANSPORT=http
PORT=3131
WINTERBRAIN_PUBLIC_URL=https://brain.winterkpital.com

# Comma-separated list of: token:userId|scope|ttlSeconds
WINTERBRAIN_TOKENS=serge_token_sergio:sergio|tools|2592000,marina_token_mariana:marina|tools|2592000,ceo_token_dario:dario|tools|31536000

# Only enable for local development without auth. Never set this in Dokploy.
# WINTERBRAIN_ALLOW_ANONYMOUS=true

# Storage root for Markdown + raw files.
BRAIN_DATA_DIR=/app/brain

# Optional: override the MarkItDown CLI command (defaults to PATH lookup).
# MARKITDOWN_COMMAND=markitdown