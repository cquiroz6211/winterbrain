{
  "name": "company-brain-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP gateway scaffold for a business-facing company brain.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "start:http": "MCP_TRANSPORT=http node dist/server.js",
    "dev:http": "MCP_TRANSPORT=http tsx src/server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  }
}
